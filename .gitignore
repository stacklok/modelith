/bin/
/dist/
# The built binary at repo root (anchored so it does not match the cmd/modelith/ dir).
/modelith
*.out

# Task runner checksums (local state, not repo artifacts)
.task/

# Personal Claude Code settings (permission grants, etc.)
.claude/settings.local.json

# Repo-local scratch space: browsable in the checkout, never committed.
# The README is the one tracked file so the directory documents itself.
/.scratch/*
!/.scratch/README.md

# Local-only running-state file (current state, decisions in flight, next
# steps). Never committed; see CLAUDE.md.
/HANDOFF.md
